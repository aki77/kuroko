{
  "name": "kuroko",
  "version": "0.1.0",
  "private": true,
  "description": "文字起こしをリアルタイム監視し、会議中に補足情報や聞くべきことを提案するCluely風オーバーレイ",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.preload.json && pnpm run copy-renderer",
    "copy-renderer": "node scripts/copy-renderer.mjs",
    "start": "pnpm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "dev": "tsc -w -p tsconfig.json & tsc -w -p tsconfig.preload.json & wait",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "pretest": "biome check . && tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.0.0",
    "electron": "^34.0.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "chokidar": "^4.0.0"
  }
}
